                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="simple_notes" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Numbered Arrow Meaning&lt;/b&gt;&lt;br/&gt;&lt;b&gt;1 request&lt;/b&gt;: dashboard or client sends HTTP call into the FastAPI route in &lt;i&gt;api/scoring_api.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;2 validate + auth&lt;/b&gt;: Pydantic request model + &lt;i&gt;require_api_key()&lt;/i&gt; validate the input and access&lt;br/&gt;&lt;b&gt;3 route chooses path&lt;/b&gt;: route decides whether to use live scoring, customer drilldown, or the scored snapshot path&lt;br/&gt;&lt;b&gt;4 fetch / snapshot source&lt;/b&gt;: &lt;i&gt;ApiCache&lt;/i&gt; either serves &lt;b&gt;snapshot_records&lt;/b&gt; from &lt;i&gt;load_scored_snapshot()/get_scored_page()&lt;/i&gt; or refreshes source data via &lt;i&gt;load_full_dataset()&lt;/i&gt;&lt;br/&gt;&lt;b&gt;5 raw docs -&amp;gt; frame&lt;/b&gt;: MongoDB &lt;b&gt;Risk.Main&lt;/b&gt; documents are fetched and flattened/canonicalized into &lt;b&gt;raw_canonical_df&lt;/b&gt;&lt;br/&gt;&lt;b&gt;6 engineered columns&lt;/b&gt;: the canonical frame becomes &lt;b&gt;scoring_frame_df&lt;/b&gt; with derived date, ratio, history, and entity features&lt;br/&gt;&lt;b&gt;7 feature matrix&lt;/b&gt;: &lt;b&gt;feature_matrix_df&lt;/b&gt; is the model input created by selecting the exact XGBoost feature columns&lt;br/&gt;&lt;b&gt;8 scored_df&lt;/b&gt;: &lt;i&gt;score_production_frame()&lt;/i&gt; returns &lt;b&gt;scored_df&lt;/b&gt; with &lt;b&gt;pd&lt;/b&gt;, &lt;b&gt;score&lt;/b&gt;, &lt;b&gt;risk_band&lt;/b&gt;, &lt;b&gt;approval&lt;/b&gt;, and &lt;b&gt;top_features&lt;/b&gt;&lt;br/&gt;&lt;b&gt;9 JSON payload&lt;/b&gt;: response builder converts the frame into final API records/summary returned to the UI&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#666666;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="120" y="3385" width="1450" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="simple_funcs" value="&lt;div style=&quot;text-align:left;&quot;&gt;&lt;b&gt;Important Hierarchical Functions / Files&lt;/b&gt;&lt;br/&gt;&lt;b&gt;Dashboard / Client&lt;/b&gt;: &lt;i&gt;credit-risk-dashboard/&lt;/i&gt;&lt;br/&gt;&lt;b&gt;API Entry&lt;/b&gt;: &lt;i&gt;score()&lt;/i&gt;, &lt;i&gt;score_all()&lt;/i&gt;, &lt;i&gt;score_customer()&lt;/i&gt;, &lt;i&gt;refresh_cache()&lt;/i&gt;, &lt;i&gt;health()&lt;/i&gt; in &lt;i&gt;api/scoring_api.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Cache Hub&lt;/b&gt;: &lt;i&gt;load_full_dataset()&lt;/i&gt;, &lt;i&gt;load_scored_snapshot()&lt;/i&gt;, &lt;i&gt;get_scored_page()&lt;/i&gt;, &lt;i&gt;get_snapshot_customer_frame()&lt;/i&gt;, &lt;i&gt;refresh()&lt;/i&gt; in &lt;i&gt;api/cache.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Mongo / Config&lt;/b&gt;: &lt;i&gt;get_database()&lt;/i&gt; in &lt;i&gt;dbconnect.py&lt;/i&gt;, env helpers in &lt;i&gt;config.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Fetch + Canonicalize&lt;/b&gt;: &lt;i&gt;fetch_risk_main_frame()&lt;/i&gt;, &lt;i&gt;canonicalize_risk_main_frame()&lt;/i&gt; in &lt;i&gt;pipeline/risk_canonical.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Build / Parse&lt;/b&gt;: &lt;i&gt;build_risk_main_scoring_frame()&lt;/i&gt;, &lt;i&gt;build_risk_main_manual_request_frame()&lt;/i&gt; in &lt;i&gt;pipeline/risk_main.py&lt;/i&gt;; &lt;i&gt;parse_main_date()&lt;/i&gt;, &lt;i&gt;parse_payment_value()&lt;/i&gt; in &lt;i&gt;pipeline/parsing.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Feature Engineering&lt;/b&gt;: &lt;i&gt;build_risk_main_feature_frame()&lt;/i&gt; in &lt;i&gt;features/engineering.py&lt;/i&gt;, &lt;i&gt;add_point_in_time_customer_features()&lt;/i&gt; in &lt;i&gt;features/point_in_time.py&lt;/i&gt;, &lt;i&gt;select_model_features()&lt;/i&gt; in &lt;i&gt;features/production_registry.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Scoring&lt;/b&gt;: &lt;i&gt;load_production_artifacts()&lt;/i&gt;, &lt;i&gt;load_risk_main_registry()&lt;/i&gt;, &lt;i&gt;score_production_frame()&lt;/i&gt; in &lt;i&gt;scoring/model.py&lt;/i&gt;&lt;br/&gt;&lt;b&gt;Response&lt;/b&gt;: &lt;i&gt;response_from_raw()&lt;/i&gt;, &lt;i&gt;_shape_response_frame()&lt;/i&gt;, &lt;i&gt;_build_customer_summary_payload()&lt;/i&gt; in &lt;i&gt;api/response_builder.py&lt;/i&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D79B00;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1605" y="3385" width="1375" height="300" as="geometry"/>
                </mxCell>
            </root>
