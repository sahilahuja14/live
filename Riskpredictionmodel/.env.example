# Core MongoDB connection
# Keep DATABASE_NAME and PRODUCTION_RISK_DB_NAME aligned for this service.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=Risk
MONGO_MAX_POOL_SIZE=20
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000

# Source-mode switch for live cutover
PRODUCTION_RISK_SOURCE_MODE=risk_main
LIVE_MONGO_URI=mongodb://username:password@live-host:27017
LIVE_DB_NAME=livedb
LIVE_COLLECTION_INVOICES=invoicemasters

# Active Risk.Main production lane
PRODUCTION_MODEL_FAMILY=risk_main
PRODUCTION_RISK_DB_NAME=Risk
PRODUCTION_RISK_COLLECTION=Main
PRODUCTION_RISK_REGISTRY_PATH=models/production/risk_main_registry.json
PRODUCTION_RISK_ACTIVE_MODEL_TYPE=risk_main_xgb
PRODUCTION_RISK_ACTIVE_VERSION=risk_main_xgb_20260319_094014
PRODUCTION_RISK_TARGET_DELAY_DAYS=30
PRODUCTION_APPROVAL_THRESHOLD_POLICY=active

# API security and logging
API_KEY=
DASHBOARD_JWT_SECRET=
DASHBOARD_JWT_ALGORITHM=HS256
LOG_LEVEL=INFO
MAX_REFRESH_ERRORS=5
# Cache and refresh behavior
API_AUTO_REFRESH_ENABLED=true
API_AUTO_REFRESH_INTERVAL_SECONDS=1800
API_DATASET_CACHE_TTL_SECONDS=2100
API_HISTORY_CACHE_TTL_SECONDS=2400
API_SCORE_ALL_PAGE_DEFAULT=100
API_SCORE_ALL_PAGE_MAX=250
API_SCORED_SNAPSHOT_RETENTION_SECONDS=3600
API_LIVE_FETCH_BATCH_SIZE=1000
API_RISK_MAIN_FETCH_BATCH_SIZE=1000

# API CORS
API_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173
API_CORS_ALLOW_CREDENTIALS=true

# Optional approval-threshold overrides
API_PRODUCTION_THRESHOLD_OVERRIDE=
API_PRODUCTION_THRESHOLD_OVERRIDE_AIR=
API_PRODUCTION_THRESHOLD_OVERRIDE_OCEAN=
